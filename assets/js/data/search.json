---
layout: compress
swcache: true
permalink: /assets/js/data/search.json
---

{% comment %}
  English search index. Hidden translations are excluded and any post
  resolves to its English version where one exists, so a translated post
  (e.g. DUSDi) shows up exactly once here instead of twice.

  The resolved post is wrapped in a fresh single-item array and iterated
  via its own `for` — reassigning the outer loop's `post` variable directly
  doesn't actually override it for post-summary.html's ambient `post`
  reference, but a genuinely new `for` binding does.
{% endcomment %}

[
  {% assign visible_posts = site.posts | where_exp: 'item', 'item.hidden != true' %}
  {% for original in visible_posts %}
  {% assign resolved = original | resolve_lang: 'en' %}
  {% assign single = '' | split: '' | push: resolved %}
  {% for post in single %}
  {% assign translated_categories = '' | split: '' %}
  {% for c in post.categories %}
    {% assign translated_c = c | translate_term: 'categories', 'en' %}
    {% assign translated_categories = translated_categories | push: translated_c %}
  {% endfor %}
  {% assign translated_tags = '' | split: '' %}
  {% for t in post.tags %}
    {% assign translated_t = t | translate_term: 'tags', 'en' %}
    {% assign translated_tags = translated_tags | push: translated_t %}
  {% endfor %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "categories": {{ translated_categories | join: ', ' | jsonify }},
    "tags": {{ translated_tags | join: ', ' | jsonify }},
    "date": {{ post.date | jsonify }},
    {% capture content -%}{% include post-summary.html full_text=true %}{%- endcapture -%}
    "content": {{ content | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
  {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
